{
  "name": "ihme-core-simulator",
  "productName": "Ihme-Core Simulator",
  "version": "1.2.0",
  "description": "A simple graphical simulator for teaching students the basics of computer architecture and virtualization.",
  "main": ".webpack/main",
  "scripts": {
    "test": "jest",
    "start": "electron-forge start",
    "profile": "electron --inspect=9229 .webpack/main",
    "package": "electron-forge package",
    "make": "electron-forge make",
    "lint": "eslint --ext .ts,.tsx .",
    "docs": "typedoc"
  },
  "jest": {
    "roots": [
      "<rootDir>/src"
    ],
    "testMatch": [
      "**/?(*.)+(spec|test).+(ts|tsx|js)"
    ],
    "transform": {
      "^.+\\.(ts|tsx)$": "ts-jest"
    }
  },
  "keywords": [],
  "author": "Erik Burmester",
  "license": "MIT",
  "devDependencies": {
    "@electron-forge/cli": "7.11.1",
    "@electron-forge/maker-deb": "7.11.1",
    "@electron-forge/maker-dmg": "7.11.1",
    "@electron-forge/maker-rpm": "7.11.1",
    "@electron-forge/maker-squirrel": "7.11.1",
    "@electron-forge/maker-zip": "7.11.1",
    "@electron-forge/plugin-auto-unpack-natives": "7.11.1",
    "@electron-forge/plugin-fuses": "7.11.1",
    "@electron-forge/plugin-webpack": "7.11.1",
    "@electron/fuses": "1.8.0",
    "@jest/globals": "30.3.0",
    "@types/jest": "30.0.0",
    "@typescript-eslint/eslint-plugin": "8.58.2",
    "@typescript-eslint/parser": "8.58.2",
    "@vercel/webpack-asset-relocator-loader": "1.7.3",
    "copy-webpack-plugin": "14.0.0",
    "css-loader": "7.1.4",
    "electron": "41.2.0",
    "eslint": "9.39.4",
    "eslint-plugin-import": "2.32.0",
    "fork-ts-checker-webpack-plugin": "9.1.0",
    "jest": "30.3.0",
    "style-loader": "4.0.0",
    "ts-jest": "29.4.9",
    "ts-loader": "9.5.7",
    "ts-node": "10.9.2",
    "typedoc": "0.28.19",
    "typedoc-material-theme": "1.4.1",
    "typedoc-plugin-markdown": "4.11.0",
    "typescript": "6.0.2"
  },
  "dependencies": {
    "electron-squirrel-startup": "1.0.1"
  }
}
