{
  "compilerOptions": {
    "target": "ES2022",
    "module": "node16",
    "rootDir": "./src",
    "skipLibCheck": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "noImplicitAny": true,
    "sourceMap": true,
    "outDir": "dist",
    "moduleResolution": "node16",
    "resolveJsonModule": true,
    "types": ["jest", "node"],
    "isolatedModules": true
  },
  "include": ["src/**/*"]
}
